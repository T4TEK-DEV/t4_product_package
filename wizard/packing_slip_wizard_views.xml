<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Wizard View -->
    <record id="view_packing_slip_wizard_form" model="ir.ui.view">
        <field name="name">packing.slip.wizard.form</field>
        <field name="model">packing.slip.wizard</field>
        <field name="arch" type="xml">
            <form string="Lắp Ráp Thành Phẩm / Đóng Gói">
                <sheet>
                    <group>
                        <group>
                            <field name="request_id" readonly="1"/>
                            <field name="fg_product_id" string="Thành Phẩm"
                                   required="True"
                                   options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="barcode_input" string="Quét Mã Vạch"
                                   autofocus="1"
                                   placeholder="Quét hoặc nhập barcode/serial..."/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Linh kiện đã quét">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="product_id" context="{'list_view_ref': 't4_sti.view_t4_product_product_list'}"/>
                                    <field name="lot_id"/>
                                    <field name="qty"/>
                                    <field name="standard_price" string="Giá Mua"
                                           groups="t4_sti.group_purchase,t4_sti.group_accounting,t4_sti.group_manager,base.group_system"/>
                                    <field name="list_price" string="Giá Kho"
                                           groups="t4_sti.group_sales,t4_sti.group_accounting,t4_sti.group_manager"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_scan_barcode" string="Ghi Nhận Mã" type="object" class="btn-primary"/>
                    <button name="action_finish_pack" string="Hoàn thành Thành Phẩm" type="object" class="btn-success"/>
                    <button special="cancel" data-hotkey="z" string="Đóng" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_packing_slip_wizard" model="ir.actions.act_window">
        <field name="name">Quét Mã Lắp Ráp / Đóng Gói</field>
        <field name="res_model">packing.slip.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
