                            th, td { border: 1px solid black; padding: 4px; text-align: center; vertical-align: middle; }
                            .info-table { width: 100%; }
                            .info-table td { border: none; text-align: left; padding: 8px 0; }
                        </style>

                        <!-- Header -->
                        <div class="text-center mb-4">
                            <h2 style="border-bottom: 2px solid #333; padding-bottom: 15px; margin-bottom: 30px; font-size: 22pt; font-weight: bold;">
                                PHIẾU ĐỊNH DANH LINH KIỆN THÀNH PHẨM
                            </h2>
                        </div>

                        <!-- Thông tin chung -->
                        <div class="mb-4">
                            <table class="info-table">
                                <tr>
                                    <td style="width: 15%; font-weight: bold;">Mã phiếu:</td>
                                    <td style="width: 18%;"><span t-field="doc.name"/></td>
                                    <td style="width: 15%; font-weight: bold; padding-left: 20px;">Ngày tạo:</td>
                                    <td style="width: 20%;">
                                        <span t-field="doc.create_date"
                                              t-options="{'widget': 'datetime', 'format': 'dd/MM/yyyy HH:mm'}"/>
                                    </td>
                                    <td style="width: 17%; font-weight: bold; padding-left: 20px;">Người định danh:</td>
                                    <td style="width: 15%;"><span t-field="doc.create_uid.name"/></td>
                                </tr>
                                <tr style="height: 40px;">
                                    <td style="font-weight: bold;">Thành phẩm:</td>
                                    <td><span t-field="doc.product_id.name"/></td>
                                    <td style="font-weight: bold; padding-left: 20px;">Mã quản lý:</td>
                                    <td><span t-field="doc.lot_id.name"/></td>
                                    <td style="font-weight: bold; padding-left: 20px;">Trạng thái:</td>
                                    <td>
                                        <span t-if="doc.state == 'draft'">Nháp</span>
                                        <span t-if="doc.state == 'done'">Hoàn Tất</span>
                                        <span t-if="doc.state == 'cancel'">Đã Huỷ</span>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- Danh sách linh kiện sử dụng -->
                        <div class="mb-4">
                            <h4 style="background-color: #046598; padding: 8px; border-left: 4px solid #012e46; margin-bottom: 15px; color: white;">
                                DANH SÁCH LINH KIỆN SỬ DỤNG
                            </h4>
                            <table class="table table-bordered">
                                <thead style="background-color: #e9ecef;">
                                    <tr>
                                        <th style="width: 5%;">STT</th>
                                        <th style="width: 30%;">Tên Sản Phẩm</th>
                                        <th style="width: 15%;">Số Lượng</th>
                                        <th style="width: 17%;">Brd. S/N</th>
                                        <th style="width: 18%;">Mfr. S/N</th>
                                        <th style="width: 15%;">Mã Thẻ</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.line_ids" t-as="component">
                                        <tr>
                                            <td><span t-esc="component_index + 1"/></td>
                                            <td style="text-align: left;"><span t-field="component.product_id.name"/></td>
                                            <td><span t-field="component.quantity"/></td>
                                            <td><span t-field="component.brand_part_id"/></td>
                                            <td><span t-field="component.manufacturer_part_id"/></td>
                                            <td><span t-field="component.card_code"/></td>
                                        </tr>
                                    </t>
                                    <t t-if="not doc.line_ids">
                                        <tr>
                                            <td colspan="6" style="text-align: center; font-style: italic; color: #6c757d;">
                                                Không có linh kiện nào được sử dụng
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>

                        <!-- Ký tên -->
                        <div class="row mt-5" style="margin-top: 50px;">
                            <div class="col-8"></div>
                            <div class="col-4 text-center">
                                <div style="border-top: 1px solid #333; padding-top: 10px; margin-top: 50px; width: 200px;">
                                    <strong>NGƯỜI ĐỊNH DANH</strong>
                                    <br/>
                                    <span t-field="doc.create_uid.name"/>
                                    <br/>
                                    <small>(Ký tên)</small>
                                </div>
                            </div>
                        </div>

                        <!-- Ghi chú -->
                        <div class="mt-4" style="padding-top: 100px;">
                            <h5 style="border-bottom: 1px solid #333; padding-bottom: 5px;">GHI CHÚ:</h5>
                            <div style="height: 150px; border: 1px solid #333; margin-top: 10px; padding: 6px;">
                                <span t-field="doc.note"/>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
