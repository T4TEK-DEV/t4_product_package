<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_packing_request" model="ir.sequence">
            <field name="name">Phiếu Đóng Gói</field>
            <field name="code">packing.request</field>
            <field name="prefix">PKG/%(year)s/</field>
            <field name="padding">5</field>
        </record>

        <!-- Sequence cho t4.product.creation: dùng prefix theo type qua
             post-action ở _prepare_sequence (sau này nếu cần). Hiện đặt
             chung 1 prefix PC/. -->
        <record id="seq_t4_product_creation" model="ir.sequence">
            <field name="name">Phiếu Lắp Ráp / Định Danh</field>
            <field name="code">t4.product.creation</field>
            <field name="prefix">PC/%(year)s/</field>
            <field name="padding">5</field>
        </record>

    </data>
</odoo>
