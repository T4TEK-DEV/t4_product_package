<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit stock.view_move_line_tree — thêm cột "Phiếu Định Danh"
         clickable cho move.line tạo qua _apply_inventory của
         t4.product.creation (không có picking_id để click). -->
    <record id="view_move_line_tree_inherit_t4_creation" model="ir.ui.view">
        <field name="name">stock.move.line.list.inherit.t4_creation</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_move_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='reference']" position="after">
                <field name="t4_creation_id"
                       string="Phiếu Định Danh"
                       optional="show"
                       options="{'no_create': 1}"/>
            </xpath>
        </field>
    </record>
</odoo>
