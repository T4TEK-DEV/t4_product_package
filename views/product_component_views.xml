<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         LIST VIEW
         ============================================================ -->
    <record id="view_product_component_list" model="ir.ui.view">
        <field name="name">t4.product.component.list</field>
        <field name="model">t4.product.component</field>
        <field name="arch" type="xml">
            <list string="Linh Kiện" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="product_id" context="{'list_view_ref': 't4_sti.view_t4_product_product_list'}"/>
                <field name="quantity"/>
                <field name="product_uom_id"/>
                <field name="note"/>
            </list>
        </field>
    </record>

    <!-- ============================================================
         FORM VIEW
         ============================================================ -->
    <record id="view_product_component_form" model="ir.ui.view">
        <field name="name">t4.product.component.form</field>
        <field name="model">t4.product.component</field>
        <field name="arch" type="xml">
            <form string="Linh Kiện">
                <group>
                    <group>
                        <field name="parent_product_id" context="{'list_view_ref': 't4_sti.view_t4_product_template_list'}"/>
                        <field name="product_id" context="{'list_view_ref': 't4_sti.view_t4_product_product_list'}"/>
                    </group>
                    <group>
                        <field name="quantity"/>
                        <field name="product_uom_id"/>
                        <field name="note"/>
                    </group>
                </group>
            </form>
        </field>
    </record>

</odoo>
