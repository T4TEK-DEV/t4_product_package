<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Inherit Odoo base product.template form —
        thêm smart buttons + component tab cho sản phẩm serial.

        Logic: mọi sản phẩm tracking='serial' đều có thể là Thành Phẩm
        (có BOM) hoặc Linh Kiện của Thành Phẩm khác. Tính chất FG/component
        do ngữ cảnh lắp ráp quyết định, không có flag đánh dấu riêng.

        Phần inherit search view của t4_sti đã được di chuyển sang
        t4_sti/views/product_template_package_views.xml (vì t4_sti depend
        ngược lại t4_product_package, không thể để ref t4_sti.* ở đây).
    -->
    <record id="view_product_template_form_inherit_package" model="ir.ui.view">
        <field name="name">product.template.form.inherit.package</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <!-- Smart buttons — hiện với mọi sản phẩm serial -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_components" type="object"
                        class="oe_stat_button" icon="fa-cogs"
                        invisible="tracking != 'serial'">
                    <field name="component_count" widget="statinfo" string="Linh Kiện"/>
                </button>
                <button name="action_view_assembly_records" type="object"
                        class="oe_stat_button" icon="fa-history"
                        invisible="tracking != 'serial'">
                    <field name="assembly_count" widget="statinfo" string="Lắp Ráp"/>
                </button>
            </xpath>
            <!-- Component tab trong notebook — mở cho mọi sản phẩm serial -->
            <xpath expr="//notebook" position="inside">
                <page name="components" string="Linh Kiện (BOM)"
                      invisible="tracking != 'serial'">
                    <field name="component_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="product_id"/>
                            <field name="quantity"/>
                            <field name="product_uom_id"/>
                            <field name="note"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
