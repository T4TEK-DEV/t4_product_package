<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Phiếu Lắp Ráp / Định Danh Sản Phẩm
        ==================================

        1 form view duy nhất phục vụ cả 2 type:
          - type='assembly': hiện 2 cột "Linh kiện sử dụng" + "Linh kiện trả"
          - type='identify': hiện 1 group "Linh kiện sử dụng" full-width

        2 list view riêng:
          - history list (lịch sử phiếu đã tạo)
          - same shape, khác filter qua action.domain

        Layout copy từ v18 product.creation.wizard (SOURCE OF TRUTH:
        D:/workspaces/t4tek/odoo/extra-addons_18/STI-backend/STIs/views/
        product_creation_wizard_views.xml).
    -->

    <!-- ============================================================
         FORM VIEW
         ============================================================ -->
    <record id="view_t4_product_creation_form" model="ir.ui.view">
        <field name="name">t4.product.creation.form</field>
        <field name="model">t4.product.creation</field>
        <field name="arch" type="xml">
            <form string="Phiếu Lắp Ráp">
                <field name="type" invisible="1"/>
                <field name="is_have_printed" invisible="1"/>
                <field name="cost_currency_id" invisible="1" options="{'no_open': 1, 'no_create': 1}"/>

                <header>
                    <button name="action_print"
                            string="In"
                            type="object"
                            class="btn"
                            icon="fa-print"
                            invisible="not line_ids and not line_returned_ids"/>
                    <!-- Hoàn Thành (chỉ identify, draft) — Operator nhập xong
                         linh kiện, chuyển sang Chờ Nhập Giá để Thu Mua vào. -->
                    <button name="action_complete"
                            string="Hoàn Thành"
                            type="object"
                            class="oe_highlight"
                            confirm="Bạn có chắc chắn muốn hoàn thành phiếu định danh này không?"
                            invisible="type != 'identify' or state != 'draft' or not line_ids"/>
                    <!-- Xác Nhận (chỉ identify, waiting) — Thu Mua / Quản Lý
                         nhập giá + xác nhận → tạo lots/quants/SVL → done. -->
                    <button name="action_confirm_cost"
                            string="Xác Nhận"
                            type="object"
                            class="oe_highlight"
                            groups="t4_sti.group_purchase,t4_sti.group_manager"
                            invisible="type != 'identify' or state != 'waiting'"/>
                    <!-- Xác Nhận: chỉ dùng cho assembly. Identify dùng luồng
                         Hoàn Thành → Xác Nhận Giá. -->
                    <button name="action_confirm"
                            string="Xác Nhận"
                            type="object"
                            class="oe_highlight"
                            invisible="type == 'identify' or state == 'done' or (not line_ids and not line_returned_ids) or (type == 'assembly' and context.get('is_required_print_assembly') and not is_have_printed)"/>
                    <button name="action_cancel"
                            string="Huỷ"
                            type="object"
                            invisible="state in ('done', 'cancel')"/>
<!-- <button name="action_draft" string="Đặt về Nháp" type="object" invisible="state not in ('cancel', 'waiting')"/> -->
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,waiting,done"/>
                </header>

                <sheet>
                    <field name="lot_id" invisible="1" options="{'no_open': 1, 'no_create': 1}"/>

                    <!-- Ribbon: trạng thái chờ nhập giá (identify, waiting) -->
                    <widget name="web_ribbon"
                            title="Chờ Nhập Giá"
                            bg_color="text-bg-warning"
                            invisible="type != 'identify' or state != 'waiting'"/>

                    <div class="oe_title">
                        <h1>
                            <field name="product_id"
                                   placeholder="Thành phẩm..."
                                   readonly="True"
                                   force_save="1"
                                   options="{'no_open': True, 'no_create': True}"
                                   context="{'list_view_ref': 't4_sti.view_t4_product_product_list'}"/>
                        </h1>
                        <h3>
                            <field name="product_name" readonly="1"/>
                        </h3>
                    </div>

                    <group>
                        <group>
                            <field name="has_lines" invisible="1"/>
                            <field name="lot_name"
                                   readonly="state == 'done' or (type == 'identify' and state != 'draft') or has_lines"
                                   force_save="1"
                                   data-auto-input-order="0"
                                   placeholder="Nhập hoặc quét mã serial của thành phẩm..."/>
                            <field name="create_uid"
                                   string="Người Tạo"
                                   options="{'no_open': 1, 'no_create': 1}"
                                   readonly="1"/>
                            <field name="create_date" string="Ngày Tạo" readonly="1"/>
                        </group>
                        <group>
                            <field name="company_id"
                                   string="Công ty"
                                   readonly="1"
                                   groups="base.group_multi_company"
                                   options="{'no_create': 1, 'no_open': 1}"/>
                            <!-- Brd/Mfr S/N related từ lot_id → ẩn khi CHƯA có
                                 Mã Quản Lý TP (lot_name). Tránh hiện S/N của lot
                                 cũ khi ô FG đang trống (desync lot_id còn / lot_name
                                 mất) làm user tưởng đã quét FG. -->
                            <field name="brand_part_id" readonly="1"
                                   invisible="not lot_name"/>
                            <field name="manufacturer_part_id" readonly="1"
                                   invisible="not lot_name"/>
                            <field name="purchase_price"
                                   widget="monetary"
                                   readonly="1"
                                   groups="t4_sti.group_purchase,t4_sti.group_accounting,t4_sti.group_manager"/>
                            <field name="total_standard_price"
                                   widget="monetary"
                                   readonly="1"
                                   groups="t4_sti.group_purchase,t4_sti.group_accounting,t4_sti.group_manager"/>
                        </group>
                    </group>

                    <!-- ============================================
                         BLOCK ĐỊNH DANH (type='identify')
                         Single group, full-width, "Linh kiện sử dụng".

                         Sequential auto-input chain (data-auto-input-order):
                           1 = lot_name       (Mã Quản Lý — scan đầu tiên)
                           2 = brand_part_id  (Brd. S/N)
                           3 = manufacturer_part_id (Mfr. S/N)

                         Readonly logic:
                           - parent_state == 'done': khoá toàn bộ
                           - not product_id: khoá cột còn lại (chọn SP trước)
                           - tracking != 'serial': lot_name + S/N readonly
                             (chỉ SP serial mới có Mã Quản Lý + S/N nghiệp vụ)

                         Required:
                           - lot_name bắt buộc khi tracking='serial'
                           - Brd/Mfr S/N theo context is_have_brand /
                             is_have_manufacturer (legacy)
                         ============================================ -->
                    <group string="Linh Kiện Sử Dụng"
                           invisible="type != 'identify'"
                           class="oe_group_border">
                        <!-- Operator nhập liệu trong draft; Thu Mua nhập giá
                             trong waiting. Mỗi field có readonly riêng theo state.
                             Bảng mở để add/delete chỉ khi state='draft'. -->
                        <!-- Bảng cho draft: được phép thêm/xóa dòng -->
                        <field name="line_ids"
                               nolabel="1"
                               colspan="2"
                               readonly="state == 'done' or (not lot_name and not lot_id)" force_save="1"
                               invisible="state != 'draft'"
                               context="{
                                   'default_state': 'used',
                                   'wizard_type': type,
                                   't4_auto_input_enabled': type == 'identify',
                               }">
                            <list editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="state" column_invisible="1"/>
                                <field name="tracking" string="Tracking" optional="hide"/>
                                <field name="cost_currency_id" column_invisible="1" options="{'no_open': 1, 'no_create': 1}"/>
                                <field name="parent_state" column_invisible="1"/>
                                <field name="lot_id" column_invisible="1" options="{'no_open': 1, 'no_create': 1}"/>

                                <field name="product_id"
                                       string="Sản Phẩm"
                                       required="1"
                                       readonly="parent_state in ('waiting', 'done', 'cancel') or lot_id" force_save="1"
                                       options="{'no_open': 1, 'no_create': 1}"
                                       context="{'list_view_ref': 't4_sti.view_t4_product_product_list'}"/>
                                <field name="quantity"
                                       string="Số Lượng"
                                       readonly="parent_state in ('waiting', 'done', 'cancel') or not product_id or tracking == 'serial'"
                                       force_save="1"/>
                                <field name="lot_name"
                                       string="Mã Quản Lý"
                                       data-auto-input-order="1"
                                       required="tracking == 'serial'"
                                       readonly="parent_state in ('waiting', 'done', 'cancel') or not product_id or tracking in ('lot', 'none')" force_save="1"/>
                                <field name="brand_part_id"
                                       string="Brd. S/N"
                                       column_invisible="not context.get('is_have_brand')"
                                       required="context.get('is_have_brand') and tracking == 'serial' and not manufacturer_part_id"
                                       data-auto-input-order="2"
                                       readonly="parent_state in ('waiting', 'done', 'cancel') or not product_id or tracking in ('lot', 'none')" force_save="1"/>
                                <field name="manufacturer_part_id"
                                       string="Mfr. S/N"
                                       column_invisible="not context.get('is_have_manufacturer')"
                                       required="context.get('is_have_manufacturer') and tracking == 'serial' and not brand_part_id"
                                       data-auto-input-order="3"
                                       readonly="parent_state in ('waiting', 'done', 'cancel') or not product_id or tracking in ('lot', 'none')" force_save="1"/>
                                <!-- Thu Mua nhập giá khi state='waiting'; readonly ở mọi state khác.
                                     Kế toán thấy nhưng chỉ đọc (can_edit_standard_price=False). -->
                                <field name="standard_price"
                                       string="Đơn Giá Mua"
                                       widget="monetary"
                                       readonly="parent_state != 'waiting' or not product_id or not context.get('can_edit_standard_price')" force_save="1"
                                       groups="t4_sti.group_purchase,t4_sti.group_accounting,t4_sti.group_manager"/>
                                <field name="create_date" string="Ngày Tạo" optional="hide"/>
                                <field name="total_standard_price"
                                       string="Thành Tiền"
                                       widget="monetary"
                                       sum="Tổng Thành Tiền"
                                       groups="t4_sti.group_purchase,t4_sti.group_accounting,t4_sti.group_manager"/>
                            </list>
                        </field>
                        <!-- Bảng cho các state khác draft: KHÔNG được thêm/xóa dòng -->
                        <field name="line_ids"
                               nolabel="1"
                               colspan="2"
                               readonly="state == 'done' or (not lot_name and not lot_id)" force_save="1"
                               invisible="state == 'draft'"
                               context="{
                                   'default_state': 'used',
                                   'wizard_type': type,
                                   't4_auto_input_enabled': type == 'identify',
                               }">
                            <list editable="bottom" create="0" delete="0">
                                <field name="sequence" widget="handle"/>
                                <field name="state" column_invisible="1"/>
                                <field name="tracking" string="Tracking" optional="hide"/>
                                <field name="cost_currency_id" column_invisible="1" options="{'no_open': 1, 'no_create': 1}"/>
                                <field name="parent_state" column_invisible="1"/>
                                <field name="lot_id" column_invisible="1" options="{'no_open': 1, 'no_create': 1}"/>

                                <field name="product_id"
                                       string="Sản Phẩm"
                                       required="1"
                                       readonly="parent_state in ('waiting', 'done', 'cancel') or lot_id" force_save="1"
                                       options="{'no_open': 1, 'no_create': 1}"
                                       context="{'list_view_ref': 't4_sti.view_t4_product_product_list'}"/>
                                <field name="quantity"
                                       string="Số Lượng"
                                       readonly="parent_state in ('waiting', 'done', 'cancel') or not product_id or tracking == 'serial'"
                                       force_save="1"/>
                                <field name="lot_name"
                                       string="Mã Quản Lý"
                                       data-auto-input-order="1"
                                       required="tracking == 'serial'"
                                       readonly="parent_state in ('waiting', 'done', 'cancel') or not product_id or tracking in ('lot', 'none')" force_save="1"/>
                                <field name="brand_part_id"
                                       string="Brd. S/N"
                                       column_invisible="not context.get('is_have_brand')"
                                       required="context.get('is_have_brand') and tracking == 'serial' and not manufacturer_part_id"
                                       data-auto-input-order="2"
                                       readonly="parent_state in ('waiting', 'done', 'cancel') or not product_id or tracking in ('lot', 'none')" force_save="1"/>
                                <field name="manufacturer_part_id"
                                       string="Mfr. S/N"
                                       column_invisible="not context.get('is_have_manufacturer')"
                                       required="context.get('is_have_manufacturer') and tracking == 'serial' and not brand_part_id"
                                       data-auto-input-order="3"
                                       readonly="parent_state in ('waiting', 'done', 'cancel') or not product_id or tracking in ('lot', 'none')" force_save="1"/>
                                <!-- Thu Mua nhập giá khi state='waiting'; readonly ở mọi state khác.
                                     Kế toán thấy nhưng chỉ đọc (can_edit_standard_price=False). -->
                                <field name="standard_price"
                                       string="Đơn Giá Mua"
                                       widget="monetary"
                                       readonly="parent_state != 'waiting' or not product_id or not context.get('can_edit_standard_price')" force_save="1"
                                       groups="t4_sti.group_purchase,t4_sti.group_accounting,t4_sti.group_manager"/>
                                <field name="create_date" string="Ngày Tạo" optional="hide"/>
                                <field name="total_standard_price"
                                       string="Thành Tiền"
                                       widget="monetary"
                                       sum="Tổng Thành Tiền"
                                       groups="t4_sti.group_purchase,t4_sti.group_accounting,t4_sti.group_manager"/>
                            </list>
                        </field>
                    </group>

                    <!-- ============================================
                         BLOCK LẮP RÁP (type='assembly')
                         Hai cột: Sử dụng (trái) + Trả (phải).
                         ============================================ -->
                    <div invisible="type != 'assembly'"
                         class="d-flex flex-row gap-2">
                        <div class="flex-fill min-w-0">
                            <group string="Linh Kiện Sử Dụng" class="oe_group_border">
                                <field name="line_ids"
                                       nolabel="1"
                                       colspan="2"
                                       readonly="state == 'done' or (type == 'assembly' and not lot_name and not lot_id)" force_save="1"
                                       context="{
                                           'default_state': 'used',
                                           'wizard_type': type,
                                           't4_auto_input_enabled': type == 'assembly',
                                       }">
                                    <list editable="bottom" create="true" delete="true">
                                        <field name="sequence" widget="handle"/>
                                        <field name="state" column_invisible="1"/>
                                        <field name="tracking" column_invisible="1"/>
                                        <field name="cost_currency_id" column_invisible="1" options="{'no_open': 1, 'no_create': 1}"/>
                                        <field name="parent_state" column_invisible="1"/>
                                        <field name="lot_id" column_invisible="1" options="{'no_open': 1, 'no_create': 1}"/>

                                        <field name="product_id"
                                               string="Sản Phẩm"
                                               required="1"
                                               readonly="parent_state in ('waiting', 'done', 'cancel') or lot_id" force_save="1"
                                               options="{'no_open': 1, 'no_create': 1}"
                                               context="{'list_view_ref': 't4_sti.view_t4_product_product_list'}"/>
                                        <field name="quantity"
                                               string="Số Lượng"
                                               readonly="parent_state in ('waiting', 'done', 'cancel') or not product_id or tracking == 'serial'" force_save="1"/>
                                        <field name="lot_name"
                                               string="Mã Quản Lý"
                                               data-auto-input-order="0"
                                               readonly="parent_state in ('waiting', 'done', 'cancel') or not product_id or tracking in ('lot', 'none') or (tracking == 'serial' and lot_id)" force_save="1"/>
                                        <field name="brand_part_id"
                                               string="Brd. S/N"
                                               readonly="parent_state in ('waiting', 'done', 'cancel') or not product_id or tracking in ('lot', 'none') or (tracking == 'serial' and lot_id)" force_save="1"/>
                                        <field name="manufacturer_part_id"
                                               string="Mfr. S/N"
                                               readonly="parent_state in ('waiting', 'done', 'cancel') or not product_id or tracking in ('lot', 'none') or (tracking == 'serial' and lot_id)" force_save="1"/>
                                        <field name="create_date" string="Ngày Tạo" optional="hide"/>
                                    </list>
                                </field>
                            </group>
                        </div>
                        <div class="flex-fill min-w-0">
                            <group string="Linh Kiện Trả" class="oe_group_border">
                                <field name="line_returned_ids"
                                       nolabel="1"
                                       colspan="2"
                                       readonly="state == 'done' or (not lot_name and not lot_id)" force_save="1"
                                       context="{'default_state': 'returned', 'wizard_type': type}">
                                    <list editable="bottom" create="true" delete="true"
                                          decoration-warning="not is_scrap"
                                          decoration-danger="is_scrap">
                                        <field name="sequence" widget="handle"/>
                                        <field name="state" column_invisible="1"/>
                                        <field name="tracking" column_invisible="1"/>
                                        <field name="parent_state" column_invisible="1"/>
                                        <field name="lot_id" column_invisible="1" options="{'no_open': 1, 'no_create': 1}"/>

                                        <field name="product_id"
                                               string="Sản Phẩm"
                                               required="1"
                                               readonly="parent_state in ('waiting', 'done', 'cancel') or lot_id" force_save="1"
                                               options="{'no_open': 1, 'no_create': 1}"
                                               context="{'list_view_ref': 't4_sti.view_t4_product_product_list'}"/>
                                        <field name="quantity"
                                               string="Số Lượng"
                                               readonly="parent_state in ('waiting', 'done', 'cancel') or not product_id or tracking == 'serial'" force_save="1"/>
                                        <field name="lot_name"
                                               string="Mã Quản Lý"
                                               data-auto-input-order="0"
                                               readonly="parent_state in ('waiting', 'done', 'cancel') or not product_id or tracking in ('lot', 'none') or (tracking == 'serial' and lot_id)" force_save="1"/>
                                        <field name="brand_part_id"
                                               string="Brd. S/N"
                                               readonly="parent_state in ('waiting', 'done', 'cancel') or not product_id or tracking in ('lot', 'none') or (tracking == 'serial' and lot_id)" force_save="1"/>
                                        <field name="manufacturer_part_id"
                                               string="Mfr. S/N"
                                               readonly="parent_state in ('waiting', 'done', 'cancel') or not product_id or tracking in ('lot', 'none') or (tracking == 'serial' and lot_id)" force_save="1"/>
                                        <field name="is_scrap"
                                               string="Hư Hỏng"
                                               readonly="parent_state == 'done'" force_save="1"/>
                                        <field name="note"
                                               string="Ghi Chú"
                                               required="is_scrap"/>
                                        <field name="create_date" string="Ngày Tạo" optional="hide"/>
                                    </list>
                                </field>
                            </group>
                        </div>
                    </div>

                    <!-- ============================================
                         NOTEBOOK: Ghi chú & Hình ảnh xác minh
                         ============================================ -->
                    <notebook>
                        <page string="Ghi Chú &amp; Hình Ảnh Xác Minh" name="notes">
                            <field name="note"
                                   readonly="state == 'done'" force_save="1"
                                   placeholder="Ghi chú nội bộ..."/>
                            <separator string="Hình Ảnh Xác Minh"/>
                            <field name="image_tracking_filename" invisible="1"/>
                            <div invisible="not image_tracking">
                                <button name="action_download_image_tracking"
                                        type="object"
                                        string="Tải Hình Về"
                                        icon="fa-download"
                                        class="btn btn-secondary"/>
                            </div>
                            <!-- image_tracking readonly tuyệt đối: path duy nhất
                                 để set là wizard `t4.product.creation.sign.wizard`,
                                 mở khi action_confirm gặp config require_print. -->
                            <field name="image_tracking"
                                   widget="image"
                                   filename="image_tracking_filename"
                                   options="{'size': [600, 0]}"
                                   readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============================================================
         FORM VIEW (LINE) — dùng khi user click vào dòng linh kiện
         trong tab "Linh Kiện Đã Lắp" trên stock.quant form.
         Read-only + chặn mở/tạo m2o (per t4_sti CLAUDE.md convention).
         ============================================================ -->
    <record id="view_t4_product_creation_line_form" model="ir.ui.view">
        <field name="name">t4.product.creation.line.form</field>
        <field name="model">t4.product.creation.line</field>
        <field name="arch" type="xml">
            <form string="Linh Kiện Đã Lắp" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="creation_id" string="Phiếu"
                                   options="{'no_open': 1, 'no_create': 1}"/>
                            <field name="product_id" string="Linh Kiện"
                                   options="{'no_open': 1, 'no_create': 1}"/>
                            <field name="lot_id" string="Mã Quản Lý"
                                   options="{'no_open': 1, 'no_create': 1}"/>
                            <field name="quantity"/>
                            <field name="product_uom_id" string="Đơn Vị"
                                   options="{'no_open': 1, 'no_create': 1}"/>
                        </group>
                        <group>
                            <field name="brand_part_id" invisible="not brand_part_id"/>
                            <field name="manufacturer_part_id" invisible="not manufacturer_part_id"/>
                            <field name="standard_price" widget="monetary"
                                   options="{'currency_field': 'cost_currency_id'}"
                                   groups="t4_sti.group_purchase,t4_sti.group_accounting,t4_sti.group_manager,base.group_system"/>
                            <field name="list_price" widget="monetary"
                                   options="{'currency_field': 'cost_currency_id'}"
                                   groups="t4_sti.group_sales,t4_sti.group_accounting,t4_sti.group_manager"/>
                            <field name="cost_currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group string="Ghi Chú" invisible="not note">
                        <field name="note" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================
         LIST VIEW (lịch sử)
         ============================================================ -->
    <record id="view_t4_product_creation_list" model="ir.ui.view">
        <field name="name">t4.product.creation.list</field>
        <field name="model">t4.product.creation</field>
        <field name="arch" type="xml">
            <list string="Lịch Sử Phiếu"
                  decoration-success="state == 'done'"
                  decoration-muted="state == 'cancel'">
                <field name="create_date" string="Ngày Tạo"/>
                <field name="name"/>
                <field name="product_id" context="{'list_view_ref': 't4_sti.view_t4_product_product_list'}"/>
                <field name="lot_id" options="{'no_open': 1, 'no_create': 1}"/>
                <field name="type" widget="badge"
                       decoration-info="type == 'assembly'"
                       decoration-warning="type == 'identify'"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-info="state == 'draft'"
                       decoration-danger="state == 'cancel'"/>
                <field name="create_uid" options="{'no_open': 1, 'no_create': 1}"/>
            </list>
        </field>
    </record>

    <!-- ============================================================
         SEARCH VIEW
         ============================================================ -->
    <record id="view_t4_product_creation_search" model="ir.ui.view">
        <field name="name">t4.product.creation.search</field>
        <field name="model">t4.product.creation</field>
        <field name="arch" type="xml">
            <search string="Tìm Phiếu">
                <field name="name"/>
                <field name="product_id"/>
                <field name="lot_id"/>
                <field name="create_uid"/>
                <separator/>
                <filter name="filter_draft" string="Nháp"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="filter_done" string="Hoàn Thành"
                        domain="[('state', '=', 'done')]"/>
                <filter name="filter_cancel" string="Đã Huỷ"
                        domain="[('state', '=', 'cancel')]"/>
                <separator/>
                <group>
                    <filter name="group_state" string="Trạng Thái"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_type" string="Loại Phiếu"
                            context="{'group_by': 'type'}"/>
                    <filter name="group_product" string="Thành Phẩm"
                            context="{'group_by': 'product_id'}"/>
                    <filter name="group_create_date" string="Ngày Tạo"
                            context="{'group_by': 'create_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================
         ACTIONS — Lắp Ráp (type='assembly')
         ============================================================ -->
    <!-- Tạo phiếu lắp ráp mới (form trực tiếp) — gắn vào menu Lắp Ráp.
         t4_passive_buttons render nút "Quét" trên status bar (do
         t4_passivehid_bridge patch StatusBarButtons). Bridge optional —
         nếu module bridge không cài, context bị bỏ qua (graceful). -->
    <record id="action_t4_product_creation_assembly_new" model="ir.actions.act_window">
        <field name="name">Lắp Ráp</field>
        <field name="res_model">t4.product.creation</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_t4_product_creation_form"/>
        <field name="target">current</field>
        <field name="context">{
            'default_type': 'assembly',
            'create': 1,
            'breadcrumb_name': 'Phiếu Lắp Ráp',
            't4_auto_input_enabled': True,
            't4_passive_data_handler': True,
            't4_passive_buttons': [{
                'id': 'rfid_reader',
                'title': 'Quét',
                'icon': 'fa-rss',
                'position': 'status_bar',
                'url': 'ws://127.0.0.1:9001',
                'toggle': False,
                'timeout': 2000,
                'target_field': 'lot_name',
                'hide_when_field_in': {'field': 'state', 'values': ['waiting', 'done', 'cancel']},
            }],
        }</field>
    </record>

    <!-- Lịch sử phiếu lắp ráp — gắn vào menu Quản Lý → Phiếu Lắp Ráp -->
    <record id="action_t4_product_creation_assembly_history" model="ir.actions.act_window">
        <field name="name">Phiếu Lắp Ráp</field>
        <field name="res_model">t4.product.creation</field>
        <field name="view_mode">list,form</field>
        <!-- Lọc theo vai trò (hardcode vào domain, user không bỏ được):
             - Kế Toán thuần: phiếu waiting+done của MỌI người (t4_pc_own=-1,
               t4_pc_acc_states=['waiting','done']).
             - Vai trò khác (kể cả admin/manager): chỉ phiếu MÌNH phụ trách
               (t4_pc_own=uid, t4_pc_acc_states=[]).
             Context inject từ t4_sti.ir_http.session_info. Default an toàn khi
             thiếu key (t4_sti chưa cài): own=uid, acc_states=[] → phiếu của tôi. -->
        <field name="domain">[('type', '=', 'assembly'),
            '|', ('responsibility.user_ids', '=', context.get('t4_pc_own', uid)),
                 ('state', 'in', context.get('t4_pc_acc_states', []))]</field>
        <field name="search_view_id" ref="view_t4_product_creation_search"/>
        <field name="context">{
            'default_type': 'assembly',
            'create': 1,
            't4_auto_input_enabled': True,
            't4_passive_data_handler': True,
            't4_passive_buttons': [{
                'id': 'rfid_reader',
                'title': 'Quét',
                'icon': 'fa-rss',
                'position': 'status_bar',
                'url': 'ws://127.0.0.1:9001',
                'toggle': False,
                'timeout': 2000,
                'target_field': 'lot_name',
                'hide_when_field_in': {'field': 'state', 'values': ['waiting', 'done', 'cancel']},
            }],
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Chưa có phiếu lắp ráp nào.
            </p>
        </field>
    </record>

    <record id="action_t4_product_creation_assembly_history_view_list" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_t4_product_creation_list"/>
        <field name="act_window_id" ref="action_t4_product_creation_assembly_history"/>
    </record>
    <record id="action_t4_product_creation_assembly_history_view_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_t4_product_creation_form"/>
        <field name="act_window_id" ref="action_t4_product_creation_assembly_history"/>
    </record>

