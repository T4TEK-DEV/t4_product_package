<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_inherit_t4_packing" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.t4.packing</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_create_packing_request" 
                        string="Mang Lắp Ráp Thành Phẩm" 
                        type="object" 
                        class="btn-primary" 
                        invisible="state not in ('confirmed', 'assigned')" />
            </xpath>
            <xpath expr="//sheet" position="before">
                <div class="alert alert-warning" role="alert" invisible="is_locked_by_packing == False">
                    Phiếu xuất kho này hiện đang bị **khóa** do đang trong quá trình lắp ráp thành phẩm (đóng gói). Vui lòng hoàn thành Yêu Cầu Lắp Ráp liên quan để tiếp tục xuất kho.
                </div>
            </xpath>
            <xpath expr="//field[@name='origin']" position="after">
                <field name="is_locked_by_packing" invisible="1"/>
            </xpath>
            <!-- Trong thực tế có thể cần disable button Validate nếu is_locked_by_packing == True -->
            <xpath expr="//button[@name='button_validate']" position="attributes">
                <attribute name="invisible">is_locked_by_packing == True</attribute>
            </xpath>
        </field>
    </record>
</odoo>
