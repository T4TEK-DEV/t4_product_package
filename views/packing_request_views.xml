<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_packing_request_form" model="ir.ui.view">
        <field name="name">packing.request.form</field>
        <field name="model">packing.request</field>
        <field name="arch" type="xml">
            <form string="Phiếu Lắp Ráp / Đóng Gói">
                <header>
                    <button name="action_confirm" string="Xác nhận" type="object" invisible="state != 'draft'" class="oe_highlight"/>
                    <button name="%(t4_product_package.action_t4_product_creation_assembly_new)d"
                            string="Tạo Phiếu Lắp Ráp"
                            type="action"
                            invisible="state != 'open'"
                            class="oe_highlight"
                            context="{'default_packing_request_id': id, 'default_type': 'assembly'}"/>
                    <button name="action_done" string="Hoàn thành yêu cầu" type="object" invisible="state != 'open'" class="oe_highlight"/>
                    <button name="action_cancel" string="Hủy bỏ" type="object" invisible="state in ('done','cancel')"/>
                    <button name="action_draft" string="Chuyển về Nháp" type="object" invisible="state != 'cancel'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,open,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_assembly_records" type="object"
                                class="oe_stat_button" icon="fa-history">
                            <field name="assembly_count" widget="statinfo" string="Lắp Ráp"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="picking_id"/>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="company_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Danh sách linh kiện yêu cầu">
                            <field name="request_line_ids">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="product_uom_qty"/>
                                    <field name="qty_packed"/>
                                    <field name="product_uom"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_packing_request_list" model="ir.ui.view">
        <field name="name">packing.request.list</field>
        <field name="model">packing.request</field>
        <field name="arch" type="xml">
            <list string="Yêu Cầu Lắp Ráp / Đóng Gói">
                <field name="name"/>
                <field name="picking_id"/>
                <field name="partner_id"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'open'" decoration-success="state == 'done'"/>
            </list>
        </field>
    </record>

    <record id="action_packing_request" model="ir.actions.act_window">
        <field name="name">Yêu Cầu Lắp Ráp Thành Phẩm</field>
        <field name="res_model">packing.request</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu riêng dưới Stock/Inventory gốc đã xoá: 2 menu action_packing_request
         và action_assembly_record giờ được host ngay trong cây STI qua override
         t4_sti.menu_assembly + t4_sti.menu_assembly_history (views/menus.xml). -->
</odoo>
